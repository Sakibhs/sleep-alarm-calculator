<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ splash screen API.
         Uses the adaptive-icon foreground (transparent background) on top of
         our solid splash colour, instead of the launcher's full adaptive icon
         (which would bleed its blue gradient circle around the clock). -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="android:windowBackground">@color/splash_background</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/splash_background</item>
    </style>
</resources>
